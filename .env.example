# ============================================================
# ACCELYO - Variables d'environnement
# ============================================================
# ATTENTION: Ce fichier est un MODELE.
# Copier vers .env et remplir avec des vraies valeurs.
# Ne JAMAIS commiter le fichier .env reel sur git.
# Toutes les cles doivent etre generees aleatoirement (openssl rand).
# ============================================================

# ----- Mode de deploiement -----
# Valeurs possibles: cloud | on_premise
DEPLOYMENT_MODE=cloud
NODE_ENV=development

# ----- Base de donnees PostgreSQL -----
# ATTENTION: Le mot de passe doit faire MINIMUM 32 caracteres en production.
DATABASE_URL=postgresql://accelyo_user:CHANGE_ME@localhost:5432/accelyo
DB_USER=accelyo_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_32_CHARS
DB_NAME=accelyo
DB_HOST=localhost
DB_PORT=5432

# ----- Cache Redis -----
# Le mot de passe est obligatoire en production.
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- Securite / JWT / Chiffrement -----
# Generer avec: openssl rand -hex 32 (pour les secrets)
# Generer avec: openssl rand -hex 16 (pour ENCRYPTION_KEY = 32 bytes hex = 16 bytes)
# NE JAMAIS reutiliser les memes valeurs entre dev/staging/prod.
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_HEX
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_64_CHARS_HEX_DIFFERENT
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX_64_CHARS

# Cles RSA pour signer les cartes (generer avec openssl genrsa -out key.pem 4096)
# ATTENTION: La cle privee ne doit JAMAIS sortir du serveur.
RSA_PRIVATE_KEY_PATH=./secrets/rsa_private.pem
RSA_PUBLIC_KEY_PATH=./secrets/rsa_public.pem

# ----- API -----
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=https://api.accelyo.fr

# Origines CORS autorisees (separer par des virgules)
CORS_ORIGINS=https://app.accelyo.fr,https://accelyo.fr

# ----- MinIO (stockage S3 local) -----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_USER=CHANGE_ME_ADMIN_USER
MINIO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=accelyo-media

# ----- SMTP (envoi d'emails) -----
SMTP_HOST=smtp.ovh.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@accelyo.fr
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM="Accelyo <no-reply@accelyo.fr>"

# ----- Izly (paiement universitaire CROUS) -----
# Si API partenaire disponible. Sinon mode deeplink uniquement.
IZLY_MODE=deeplink
IZLY_API_KEY=
IZLY_API_URL=https://api.izly.fr

# ----- Monitoring (Prometheus / Grafana) -----
PROMETHEUS_PASSWORD=CHANGE_ME
GRAFANA_PASSWORD=CHANGE_ME

# ----- Dashboard public URL -----
DASHBOARD_URL=https://app.accelyo.fr

# ----- Rate limiting (override des defauts si besoin) -----
# Toutes les valeurs sont en millisecondes ou en compteur.
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
