{
  "expo": {
    "name": "Accelyo",
    "slug": "accelyo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "scheme": "accelyo",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.accelyo.app",
      "infoPlist": {
        "NFCReaderUsageDescription": "Pour utiliser ta carte etudiante NFC"
      }
    },
    "android": {
      "package": "fr.accelyo.app",
      "permissions": ["android.permission.NFC"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication"
    ]
  }
}
